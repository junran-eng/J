# ============================================================
# AI Marketing Workflow - Environment Configuration
# 复制为 .env 并填入实际值
# ============================================================

# ---- DeepSeek API ----
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# ---- LLM Model ----
# 推荐：deepseek-v4-flash / deepseek-v4-pro / deepseek-chat
LLM_MODEL=deepseek-v4-flash

# ---- Source API Keys (Optional) ----
# NEWSAPI_KEY=your-newsapi-key

# ---- Scheduler ----
SCHEDULER_TIMEZONE=Asia/Shanghai

# ---- Output ----
OUTPUT_DIR=./outputs

# ---- Logging ----
LOG_LEVEL=INFO

# ---- Webhook 通知（可选）----
# 定时任务完成后发送通知。留空则不启用。
# WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# WEBHOOK_TYPE=wecom     # wecom | feishu | generic

# ---- 端点路径（可选，不设则用 OpenAI 标准路径）----
# OPENAI_CHAT_PATH=/v1/chat/completions
# OPENAI_EMBED_PATH=/v1/embeddings
